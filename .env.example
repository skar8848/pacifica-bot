# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Pacifica
PACIFICA_NETWORK=testnet
BUILDER_CODE=
BUILDER_FEE_RATE=0.0005

# Encryption key for agent wallets
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# PostgreSQL (required)
# Free options: Neon.tech, Supabase, or Render Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# Bot identity
BOT_USERNAME=trident_pacifica_bot
ADMIN_IDS=

# Render keep-alive (auto-set by Render, or set manually)
# RENDER_EXTERNAL_URL=https://your-service.onrender.com

# Devnet dispenser (auto-sends SOL+USDC to new wallets)
# DISPENSER_PRIVATE_KEY=your_base58_key
# DISPENSER_SOL_AMOUNT=0.02
# DISPENSER_USDC_AMOUNT=3000
